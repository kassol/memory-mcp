# Server
MEMORY_MCP_HOST=0.0.0.0
MEMORY_MCP_PORT=8765
MEMORY_MCP_DEBUG=false

# Authentication
MEMORY_MCP_AUTH_TOKEN=your-secure-token-here

# Storage
MEMORY_MCP_DATA_DIR=./data
# lancedb | memory | auto
MEMORY_MCP_VECTOR_BACKEND=lancedb

# Embedding (OpenRouter)
MEMORY_MCP_OPENROUTER_API_KEY=sk-or-v1-xxxxx
MEMORY_MCP_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
MEMORY_MCP_EMBEDDING_MODEL=openai/text-embedding-3-small
MEMORY_MCP_EMBEDDING_DIM=1536

# Conflict Detection (Optional)
# MEMORY_MCP_SIMILARITY_THRESHOLD=0.85
# MEMORY_MCP_LLM_MODEL=anthropic/claude-3-haiku
CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token
